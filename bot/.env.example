# ===== Bot-Member-Zalo — cấu hình (Milestone 1) =====
# Copy file này thành .env rồi điền giá trị thật. KHÔNG commit .env.

# --- Group ---
# ID của group Zalo cần quản lý (lấy từ lệnh export-members hoặc init-seed lần đầu).
GROUP_ID=

# Số thành viên muốn giữ lại sau mỗi kỳ dọn dẹp (brainstorm: 965).
TARGET_MEMBER_COUNT=965

# --- Lưu trữ ---
# Đường dẫn file SQLite (đĩa persistent trên VPS).
SQLITE_DB_PATH=./data/bot.db

# Thư mục lưu session đăng nhập Zalo (cookie/imei). KHÔNG commit.
SESSION_DIR=./data

# --- Làm nóng (warmup) ---
# Số ngày bot chỉ quan sát, chưa kick (brainstorm: 30 ngày).
WARMUP_DAYS=30

# --- An toàn ---
# 1 = dry-run (không kick thật). Milestone 1 chưa có job kick nên luôn để 1.
DRY_RUN=1

# Nghỉ giữa mỗi lần gọi Zalo nặng (ms) — chống bị flag. init-seed dùng giá trị này.
ZALO_THROTTLE_MS=1500

# --- init-seed (chỉ dùng khi chạy lệnh init-seed bằng TÀI KHOẢN CHÍNH, read-only) ---
# Số tháng lịch sử chat tối đa muốn kéo về khi seed (0 = kéo tối đa tới trần an toàn).
SEED_MAX_MONTHS=0
# Trần an toàn số lần gọi lấy lịch sử chat (chặn vòng lặp vô hạn / tránh flag acc chính).
SEED_MAX_PAGES=200
