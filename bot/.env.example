# ===== Bot-Member-Zalo — cấu hình =====
# Copy file này thành .env rồi điền giá trị thật. KHÔNG commit .env.

# --- Group ---
# ID của group Zalo cần quản lý (lấy bằng lệnh `npm run list-groups`).
GROUP_ID=

# Số thành viên muốn giữ lại sau mỗi kỳ dọn dẹp (brainstorm: 965).
TARGET_MEMBER_COUNT=965

# --- Lưu trữ ---
# Đường dẫn file SQLite (đĩa persistent trên VPS).
SQLITE_DB_PATH=./data/bot.db

# Thư mục lưu session đăng nhập Zalo (cookie/imei). KHÔNG commit.
SESSION_DIR=./data

# --- Làm nóng (warmup) ---
# Số ngày bot chỉ quan sát, chưa kick (brainstorm: 30 ngày).
WARMUP_DAYS=30

# --- An toàn ---
# 1 = dry-run (không gửi cảnh báo/kick thật). Để 1 khi test danh sách.
DRY_RUN=1

# Nghỉ giữa mỗi lần gọi Zalo nặng (ms) — chống bị flag (đọc member/poll).
ZALO_THROTTLE_MS=1500

# In heartbeat để biết listener còn sống. 0 = tắt.
LISTENER_HEARTBEAT_MS=60000

# Chủ động sync danh sách member trong listener mỗi N ms. 0 = tắt sync chủ động.
# Mặc định 30 phút: đủ để sửa lệch khi admin xóa tay hoặc WebSocket rớt group_event.
LISTENER_MEMBER_SYNC_INTERVAL_MS=1800000

# Log mỗi N event message/reaction nhận được. 1 = log từng event, 0 = tắt.
LISTENER_EVENT_LOG_EVERY=1

# 1 = listener cũng nhận event do chính tài khoản bot gửi để lưu text message.
# Self-message cũng được ghi interaction và tính vào ranking cleanup.
ZALO_SELF_LISTEN=1

# Trần số member xoá trong một kỳ cleanup.
MAX_KICKS_PER_RUN=50

# Nghỉ giữa mỗi lần kick thật (ms). Brainstorm: 2 phút.
KICK_THROTTLE_MS=120000

# File JSON danh sách trắng: [] hoặc [{"id":"zalo_user_id","note":"VIP"}].
VIP_LIST_PATH=./data/vip-list.json

# 1 = cho phép `npm run cleanup-warn` gửi cảnh báo vào group khi DRY_RUN=0.
SEND_GROUP_WARNINGS=0

# --- Telegram approval (Milestone 2) ---
# Tạo bot qua @BotFather, lấy token; lấy chat id admin rồi điền vào đây.
# Khi hai biến này có giá trị và DRY_RUN=0, monthly-cleanup sẽ gửi danh sách chờ duyệt.
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Không phản hồi sau N giờ thì telegram-poll tự động chạy cleanup.
APPROVAL_TIMEOUT_HOURS=48

# --- Web dashboard ---
# Đổi nếu VPS đã có ứng dụng dùng port 3000.
WEB_PORT=5831
